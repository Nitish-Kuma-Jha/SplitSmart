PORT=5000
MONGO_URI=mongodb://localhost:27017/splitwise
JWT_SECRET=replace_with_long_random_string_here
JWT_EXPIRE=7d

# Gmail SMTP (get App Password from Google Account > Security > 2FA > App Passwords)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_16_char_app_password

CLIENT_URL=http://localhost:5173

# Note: In development without email config, OTP is returned in API response as devOtp
# and shown as a toast notification in the UI
